// wrangler.jsonc
{
	"name": "portfolio-astrojs",
	"compatibility_date": "2026-06-27",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "a7c848a39b794c32ae1ced4fd9703368",
			"remote": true
		}
	],
	"observability": {
		"enabled": true
	}
}
